DATABASE_URL=postgresql://postgres:postgres@localhost:5432/solar_shadow_solver
SESSION_SECRET=change-this-long-random-secret
PORT=3001

# Optional AI features
ANTHROPIC_API_KEY=

# First local/admin login created on API startup.
BOOTSTRAP_ADMIN_EMAIL=admin@example.local
BOOTSTRAP_ADMIN_PASSWORD=change-this-password
BOOTSTRAP_ADMIN_NAME=Administrador
BOOTSTRAP_COMPANY_NAME=SolarDim
BOOTSTRAP_COMPANY_NIF=
BOOTSTRAP_COMPANY_PHONE=
BOOTSTRAP_COMPANY_ADDRESS=
BOOTSTRAP_COMPANY_PRIMARY_COLOR=#0D2B45
BOOTSTRAP_COMPANY_SECONDARY_COLOR=#F5A623

# Optional second/partner login for shared installs.
# BOOTSTRAP_USERS_JSON can also be used for multiple users.
BOOTSTRAP_PARTNER_EMAIL=
BOOTSTRAP_PARTNER_PASSWORD=
BOOTSTRAP_PARTNER_NAME=
BOOTSTRAP_PARTNER_COMPANY_NAME=
